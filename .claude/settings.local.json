  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "changed=$(git -C \"$(pwd)\" diff --name-only HEAD 2>/dev/null | grep '^src/' | head -1); if [ -n \"$changed\" ]; then echo '{\"systemMessage\": \"src/ files changed this session — consider updating ARCHITECTURE.md and docs/diagrams.md if the data flow or schema changed.\"}'; fi"
          }
        ]
      }
    ]
  }
