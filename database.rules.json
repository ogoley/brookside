{
  "rules": {
    ".read": true,
    "game": {
      ".write": "auth != null && (auth.token.role === 'scorer' || auth.token.role === 'admin')"
    },
    "overlay": {
      ".write": "auth != null && (auth.token.role === 'scorer' || auth.token.role === 'admin')"
    },
    "games": {
      ".write": "auth != null && (auth.token.role === 'scorer' || auth.token.role === 'admin')"
    },
    "gameStats": {
      ".write": "auth != null && (auth.token.role === 'scorer' || auth.token.role === 'admin')"
    },
    "liveRunners": {
      ".write": "auth != null && (auth.token.role === 'scorer' || auth.token.role === 'admin')"
    },
    "gameSummaries": {
      ".write": "auth != null && auth.token.role === 'admin'"
    },
    "teams": {
      ".write": "auth != null && auth.token.role === 'admin'"
    },
    "players": {
      ".write": "auth != null && auth.token.role === 'admin'",
      "$playerId": {
        ".write": "auth != null && auth.token.role === 'scorer' && ($playerId.beginsWith('sub_') || $playerId.beginsWith('subp_'))"
      }
    },
    "config": {
      ".write": "auth != null && auth.token.role === 'admin'"
    }
  }
}
