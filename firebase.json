{
  "functions": {
    "source": "functions"
  },
  "hosting": {
    "site": "brookside-14b4b",
    "public": "dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/api/generateSummary",
        "run": {
          "serviceId": "generatesummary",
          "region": "us-central1"
        }
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
